# ================================================================
# CRM-AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
# ================================================================

# ── Required ─────────────────────────────────────────────────────
# Google Gemini API key (used for AI diagnosis, drafts, policy checks)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── Server ────────────────────────────────────────────────────────
# Port the Express API server listens on (default: 3006)
API_PORT=3006

# Runtime environment: development | production | test (default: development)
NODE_ENV=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3005,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────
# Path to the SQLite database file (default: ./data/crmai.db)
DB_PATH=./data/crmai.db

# ── AI Model ─────────────────────────────────────────────────────
# Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ── Queue ─────────────────────────────────────────────────────────
# Max jobs processed in parallel by the background worker (default: 5)
QUEUE_CONCURRENCY=5

# How often the worker polls for new jobs in ms (default: 1000)
QUEUE_POLL_INTERVAL_MS=1000

# Default max retry attempts before a job is marked dead (default: 3)
QUEUE_MAX_ATTEMPTS=3

# Base delay in ms for exponential back-off between retries (default: 2000)
QUEUE_BACKOFF_BASE_MS=2000

# ── Integration defaults ──────────────────────────────────────────
# Timeout in ms for outbound API calls (default: 15000)
INTEGRATION_TIMEOUT_MS=15000

# Max retries per outbound API call (default: 3)
INTEGRATION_MAX_RETRIES=3

# Max outbound requests per minute per integration (default: 60)
INTEGRATION_RATE_LIMIT=60

# ── Shopify (Phase 1 — optional until configured) ─────────────────
# Your store: mystore.myshopify.com
SHOPIFY_SHOP_DOMAIN=
# Admin API token from your Shopify app
SHOPIFY_ADMIN_API_TOKEN=
# Webhook secret from your Shopify app (for signature verification)
SHOPIFY_WEBHOOK_SECRET=

# ── Stripe (Phase 1 — optional until configured) ──────────────────
# Secret key from the Stripe dashboard
STRIPE_SECRET_KEY=
# Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=

# ── Logging ───────────────────────────────────────────────────────
# Minimum log level: debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL=debug

# ── App URL ───────────────────────────────────────────────────────
# Public URL of this service (used for OAuth callbacks, self-referential links)
APP_URL=http://localhost:3006
