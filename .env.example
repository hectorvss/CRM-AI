# ================================================================
# CRM-AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.
# ================================================================

# ── Server ────────────────────────────────────────────────────────
# Port the Express API server listens on (default: 3006)
API_PORT=3006

# Runtime environment: development | production | test (default: development)
NODE_ENV=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3005,http://localhost:5173

# Public URL of the frontend (used for OAuth callbacks, invite links, etc.)
APP_URL=http://localhost:5173

# Minimum log level: debug | info | warn | error (default: debug in dev, info in prod)
LOG_LEVEL=debug

# ── Database (Supabase) ───────────────────────────────────────────
# Supabase is the only supported runtime database provider.
DB_PROVIDER=supabase
SUPABASE_URL=
# Anon (public) key — used by the frontend SDK
SUPABASE_ANON_KEY=
# Service role key — server-only, bypasses RLS. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ──────────────────────────────────────────────────────────
# Secret used to sign internal JWTs (when not using Supabase Auth tokens)
JWT_SECRET=
# Set to "true" in development to allow anonymous requests bypassing auth.
# Must NEVER be true in production.
ALLOW_ANON_DEV=false

# ── Default tenant context (background jobs) ─────────────────────
# Required to enable background maintenance jobs (SLA checks, reconciliation,
# workflow delay resume, session pruning, churn scans).
# Set to the UUID of your default tenant and workspace from the database.
DEFAULT_TENANT_ID=
DEFAULT_WORKSPACE_ID=

# ── AI ────────────────────────────────────────────────────────────
# Google Gemini API key (used for AI diagnosis, drafts, policy checks)
GEMINI_API_KEY=
# Gemini model to use (default: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro
# Optional alternate LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=

# ── Queue ─────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_POLL_INTERVAL_MS=1000
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_BASE_MS=2000

# ── Integration defaults ──────────────────────────────────────────
INTEGRATION_TIMEOUT_MS=15000
INTEGRATION_MAX_RETRIES=3
INTEGRATION_RATE_LIMIT=60

# ── Stripe (Billing) ──────────────────────────────────────────────
# Secret key from the Stripe dashboard
STRIPE_SECRET_KEY=
# Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=
# Publishable key (used by the frontend Checkout/Elements)
STRIPE_PUBLISHABLE_KEY=
# Optional: Stripe Price IDs for the SaaS plans (legacy — kept for back-compat)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ── Stripe pricing — plan subscriptions (monthly + annual) ───────────
# Map each plan + billing interval to a Stripe Price ID. Configure these
# from the Stripe dashboard once Products are created (see docs/billing.md).
STRIPE_PRICE_ID_STARTER_MONTHLY=
STRIPE_PRICE_ID_STARTER_ANNUAL=
STRIPE_PRICE_ID_GROWTH_MONTHLY=
STRIPE_PRICE_ID_GROWTH_ANNUAL=
STRIPE_PRICE_ID_SCALE_MONTHLY=
STRIPE_PRICE_ID_SCALE_ANNUAL=

# ── Stripe pricing — top-up packs (one-time payments) ────────────────
# 5,000 credits → €79; 20,000 credits → €249; 50,000 credits → €549
STRIPE_PRICE_ID_TOPUP_5K=
STRIPE_PRICE_ID_TOPUP_20K=
STRIPE_PRICE_ID_TOPUP_50K=

# ── Stripe pricing — flexible (metered) usage ────────────────────────
# Metered price (€0.019 per credit) appended as an additional subscription
# item when the customer enables "uso flexible" / pay-as-you-go.
STRIPE_PRICE_ID_FLEXIBLE_USAGE=

# Optional: portal return URL after billing changes
STRIPE_PORTAL_RETURN_URL=

# ── Email (Postmark) ──────────────────────────────────────────────
# Server token from Postmark — required for transactional email
# (member invitations, password resets, customer replies on email-channel cases)
POSTMARK_SERVER_TOKEN=
# From address for outgoing email — must be a verified sender signature in Postmark
EMAIL_FROM=support@example.com

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────
# Verify token configured in your Meta App dashboard (webhook handshake)
WHATSAPP_VERIFY_TOKEN=
# WhatsApp Business Account phone number ID
WHATSAPP_PHONE_NUMBER_ID=
# Meta permanent access token used to send messages
WHATSAPP_ACCESS_TOKEN=
# Optional: signing secret for inbound webhook signature verification
WHATSAPP_WEBHOOK_SECRET=

# ── Twilio (SMS) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 phone number messages are sent FROM (e.g. +14155552671)
TWILIO_PHONE=
# Alias accepted for back-compat — TWILIO_FROM_NUMBER works too
TWILIO_FROM_NUMBER=

# ── OAuth connectors ──────────────────────────────────────────────
# Google / Gmail OAuth (https://console.cloud.google.com/ → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack OAuth (https://api.slack.com/apps → OAuth & Permissions)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Microsoft / Outlook OAuth (https://portal.azure.com/ → App registrations)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# ── Shopify (optional) ────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# ── Commerce policy ───────────────────────────────────────────────
# Refund amount above which manual approval is required (default: 250)
REFUND_AUTO_APPROVAL_THRESHOLD=250
