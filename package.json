{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3005 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npm-run-all --parallel dev dev:server",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit --project tsconfig.json",
    "lint:server": "npx tsc --noEmit --project tsconfig.server.json",
    "lint:all": "npm run lint && npm run lint:server",
    "eval:super-agent": "tsx tests/super-agent/run-golden.ts",
    "eval:super-agent-policy": "tsx tests/super-agent/run-policy.ts",
    "eval:super-agent-catalog": "tsx tests/super-agent/run-tool-catalog.ts",
    "eval:super-agent-search": "tsx tests/super-agent/run-search-smoke.ts",
    "eval:super-agent-safety": "tsx tests/super-agent/run-safety.ts",
    "test:domain-interop": "tsx tests/domain-interop/run-domain-interop.ts",
    "test:settings-profile-critical": "tsx tests/settings-profile/run-critical.ts",
    "test:interop-http": "tsx tests/interop-http/run-end-to-end.ts",
    "test:e2e:interop": "tsx tests/interop-http/run-end-to-end.ts",
    "worker": "tsx server/worker-standalone.ts",
    "seed:supabase-demo": "tsx seed_sample_data.ts",
    "seed:demo": "psql $DATABASE_URL -f scripts/seed-demo.sql"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
