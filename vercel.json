{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "functions": {
    "api/index.ts": {
      "excludeFiles": "{dist/**,public-landing/**,public-landing-v2/**,landing-v2/**,landing/**,src/**,tmp-figma/**,.figma-extract/**,tests/**,scripts/**,docs/**,*.md,*.png,*.jpg,*.jpeg,*.gif,*.webp,*.svg,*.ico,**/*.test.ts,**/*.spec.ts}"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",      "destination": "/api/index" },
    { "source": "/webhooks/:path*", "destination": "/api/index" },

    { "source": "/app",             "destination": "/_spa.html" },
    { "source": "/app/:path*",      "destination": "/_spa.html" },

    { "source": "/",                "destination": "/landing-v2/index.html" },

    { "source": "/v1",                "destination": "/landing/index.html" },
    { "source": "/v1/",               "destination": "/landing/index.html" },
    { "source": "/v1/:f*",            "destination": "/landing/:f*" },

    { "source": "/v2",                "destination": "/landing-v2/index.html" },
    { "source": "/v2/",               "destination": "/landing-v2/index.html" },
    { "source": "/v2/:f*",            "destination": "/landing-v2/:f*" },

    { "source": "/ai-agent",          "destination": "/landing-v2/index.html" },
    { "source": "/ai-agent/slack",    "destination": "/landing-v2/index.html" },
    { "source": "/inbox",             "destination": "/landing-v2/index.html" },
    { "source": "/omnichannel",       "destination": "/landing-v2/index.html" },
    { "source": "/how-it-works",      "destination": "/landing-v2/index.html" },
    { "source": "/tickets",           "destination": "/landing-v2/index.html" },
    { "source": "/reporting",         "destination": "/landing-v2/index.html" },
    { "source": "/startups",          "destination": "/landing-v2/index.html" },
    { "source": "/knowledge",         "destination": "/landing-v2/index.html" },
    { "source": "/pricing",           "destination": "/landing-v2/index.html" },
    { "source": "/copilot",           "destination": "/landing-v2/index.html" },
    { "source": "/agent-customer",    "destination": "/landing-v2/index.html" },
    { "source": "/agent-trust",       "destination": "/landing-v2/index.html" },
    { "source": "/how-agent-works",   "destination": "/landing-v2/index.html" },
    { "source": "/technology",        "destination": "/landing-v2/index.html" },
    { "source": "/upgrade",           "destination": "/landing-v2/index.html" },

    { "source": "/styles.css",        "destination": "/landing-v2/styles.css" },
    { "source": "/tokens.css",        "destination": "/landing-v2/tokens.css" },
    { "source": "/shared.jsx",        "destination": "/landing-v2/shared.jsx" },
    { "source": "/app.jsx",           "destination": "/landing-v2/app.jsx" },
    { "source": "/home.jsx",          "destination": "/landing-v2/home.jsx" },
    { "source": "/inbox.jsx",         "destination": "/landing-v2/inbox.jsx" },
    { "source": "/tickets.jsx",       "destination": "/landing-v2/tickets.jsx" },
    { "source": "/reporting.jsx",     "destination": "/landing-v2/reporting.jsx" },
    { "source": "/omnichannel.jsx",   "destination": "/landing-v2/omnichannel.jsx" },
    { "source": "/startups.jsx",      "destination": "/landing-v2/startups.jsx" },
    { "source": "/how-it-works.jsx",  "destination": "/landing-v2/how-it-works.jsx" },
    { "source": "/ai-agent.jsx",      "destination": "/landing-v2/ai-agent.jsx" },
    { "source": "/ai-agent-slack.jsx","destination": "/landing-v2/ai-agent-slack.jsx" },
    { "source": "/knowledge.jsx",     "destination": "/landing-v2/knowledge.jsx" },
    { "source": "/pricing.jsx",       "destination": "/landing-v2/pricing.jsx" },
    { "source": "/copilot.jsx",       "destination": "/landing-v2/copilot.jsx" },
    { "source": "/agent-customer.jsx","destination": "/landing-v2/agent-customer.jsx" },
    { "source": "/agent-trust.jsx",   "destination": "/landing-v2/agent-trust.jsx" },
    { "source": "/paywall.jsx",       "destination": "/landing-v2/paywall.jsx" },
    { "source": "/technology.jsx",    "destination": "/landing-v2/technology.jsx" },
    { "source": "/assets/:f*",        "destination": "/landing-v2/assets/:f*" },

    { "source": "/v1/styles.css",          "destination": "/landing/styles.css" },
    { "source": "/v1/app.jsx",             "destination": "/landing/app.jsx" },
    { "source": "/v1/auth.jsx",            "destination": "/landing/auth.jsx" },
    { "source": "/v1/pages.jsx",           "destination": "/landing/pages.jsx" },
    { "source": "/v1/customers.jsx",       "destination": "/landing/customers.jsx" },
    { "source": "/v1/solutions.jsx",       "destination": "/landing/solutions.jsx" },
    { "source": "/v1/capabilities.jsx",    "destination": "/landing/capabilities.jsx" },
    { "source": "/v1/capabilities-extra.jsx","destination": "/landing/capabilities-extra.jsx" },
    { "source": "/v1/deep-pages.jsx",      "destination": "/landing/deep-pages.jsx" },
    { "source": "/v1/tweaks-panel.jsx",    "destination": "/landing/tweaks-panel.jsx" },
    { "source": "/uploads/:f*",            "destination": "/landing/uploads/:f*" },

    { "source": "/signin",          "destination": "/landing-v2/index.html" },
    { "source": "/signup",          "destination": "/landing-v2/index.html" },
    { "source": "/demo",            "destination": "/landing-v2/index.html" },
    { "source": "/reset-password",  "destination": "/landing-v2/index.html" },
    { "source": "/customers",       "destination": "/landing-v2/index.html" },
    { "source": "/super-agent",     "destination": "/landing-v2/index.html" },
    { "source": "/early-stage",     "destination": "/landing-v2/index.html" },
    { "source": "/unified-inbox",   "destination": "/landing-v2/index.html" },
    { "source": "/cases",           "destination": "/landing-v2/index.html" },
    { "source": "/help-center",     "destination": "/landing-v2/index.html" },
    { "source": "/policy-engine",   "destination": "/landing-v2/index.html" },
    { "source": "/audit-log",       "destination": "/landing-v2/index.html" },
    { "source": "/changelog",       "destination": "/landing-v2/index.html" },
    { "source": "/integrations",    "destination": "/landing-v2/index.html" },
    { "source": "/cx-models",       "destination": "/landing-v2/index.html" }
  ],
  "headers": [
    {
      "source": "/(landing|landing-v2)/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/v2/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/v2/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(landing|landing-v2)/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/v2/(.*)\\.(js|css|svg|woff2?)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    },
    {
      "source": "/v2/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "env": {
    "NODE_ENV":                "production",
    "SUPER_AGENT_LLM_ROUTING": "true"
  },
  "crons": [
    { "path": "/api/internal/worker/tick",     "schedule": "0 12 * * *" },
    { "path": "/api/internal/scheduler/tick",  "schedule": "0 12 * * *" },
    { "path": "/api/super-agent/cron/check",   "schedule": "0 0 * * *" }
  ]
}
