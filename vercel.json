{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*",      "destination": "/api/index" },
    { "source": "/webhooks/:path*", "destination": "/api/index" },

    { "source": "/app",             "destination": "/_spa.html" },
    { "source": "/app/:path*",      "destination": "/_spa.html" },

    { "source": "/",                "destination": "/landing/index.html" },

    { "source": "/styles.css",        "destination": "/landing/styles.css" },
    { "source": "/app.jsx",           "destination": "/landing/app.jsx" },
    { "source": "/auth.jsx",          "destination": "/landing/auth.jsx" },
    { "source": "/pages.jsx",         "destination": "/landing/pages.jsx" },
    { "source": "/customers.jsx",     "destination": "/landing/customers.jsx" },
    { "source": "/solutions.jsx",     "destination": "/landing/solutions.jsx" },
    { "source": "/capabilities.jsx",  "destination": "/landing/capabilities.jsx" },
    { "source": "/capabilities-extra.jsx", "destination": "/landing/capabilities-extra.jsx" },
    { "source": "/tweaks-panel.jsx",  "destination": "/landing/tweaks-panel.jsx" },
    { "source": "/uploads/:f*",       "destination": "/landing/uploads/:f*" },

    { "source": "/reset-password",  "destination": "/landing/index.html" },
    { "source": "/signin",          "destination": "/landing/index.html" },
    { "source": "/signup",          "destination": "/landing/index.html" },
    { "source": "/demo",            "destination": "/landing/index.html" },
    { "source": "/pricing",         "destination": "/landing/index.html" },
    { "source": "/product",         "destination": "/landing/index.html" },
    { "source": "/product/:path*",  "destination": "/landing/index.html" },
    { "source": "/customers",       "destination": "/landing/index.html" },
    { "source": "/omnichannel",     "destination": "/landing/index.html" },
    { "source": "/early-stage",     "destination": "/landing/index.html" },
    { "source": "/unified-inbox",   "destination": "/landing/index.html" },
    { "source": "/cases",           "destination": "/landing/index.html" },
    { "source": "/help-center",     "destination": "/landing/index.html" },
    { "source": "/reporting",       "destination": "/landing/index.html" },
    { "source": "/policy-engine",   "destination": "/landing/index.html" },
    { "source": "/audit-log",       "destination": "/landing/index.html" },
    { "source": "/copilot",         "destination": "/landing/index.html" },
    { "source": "/changelog",       "destination": "/landing/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",      "value": "https://crm-ai-rose.vercel.app" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Methods",     "value": "GET,POST,PUT,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers",     "value": "Content-Type,Authorization,x-tenant-id,x-workspace-id,x-user-id" }
      ]
    },
    {
      "source": "/landing/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/javascript; charset=utf-8" }
      ]
    }
  ],
  "env": {
    "NODE_ENV":                "production",
    "SUPABASE_URL":            "https://erzfvnpzbmwnpchhemjt.supabase.co",
    "SUPABASE_ANON_KEY":       "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVyemZ2bnB6Ym13bnBjaGhlbWp0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3OTA5MjQsImV4cCI6MjA5MTM2NjkyNH0.vtUHINHIUIJortTkqcK6ShFrnSNbjQRnj5dE8fcFTxY",
    "VITE_SUPABASE_URL":       "https://erzfvnpzbmwnpchhemjt.supabase.co",
    "VITE_SUPABASE_ANON_KEY":  "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVyemZ2bnB6Ym13bnBjaGhlbWp0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3OTA5MjQsImV4cCI6MjA5MTM2NjkyNH0.vtUHINHIUIJortTkqcK6ShFrnSNbjQRnj5dE8fcFTxY",
    "APP_URL":                 "https://crm-ai-rose.vercel.app",
    "GEMINI_MODEL":            "gemini-2.0-flash",
    "SUPER_AGENT_LLM_ROUTING": "true",
    "CORS_ORIGINS":            "https://crm-ai-rose.vercel.app,http://localhost:3005,http://localhost:5173"
  },
  "crons": [
    {
      "path": "/api/superagent/cron/check",
      "schedule": "0 0 * * *"
    }
  ]
}
